<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.flow.eda.web.flow.instance.FlowInstanceMapper">

    <resultMap id="FlowInstanceResultMap" type="com.flow.eda.web.flow.instance.FlowInstanceDO">
        <id property="id" column="id" />
        <result property="flowId" column="flow_id" />
        <result property="status" column="status" />
        <result property="triggerUser" column="trigger_user" />
        <result property="terminateReason" column="terminate_reason" />
        <result property="retryCount" column="retry_count" />
        <result property="startTime" column="start_time" />
        <result property="endTime" column="end_time" />
        <result property="createdAt" column="created_at" />
        <result property="updatedAt" column="updated_at" />
    </resultMap>

    <resultMap id="FlowInstanceNodeResultMap" type="com.flow.eda.web.flow.instance.FlowInstanceNodeDO">
        <id property="id" column="id" />
        <result property="instanceId" column="instance_id" />
        <result property="nodeId" column="node_id" />
        <result property="nodeName" column="node_name" />
        <result property="nodeType" column="node_type" />
        <result property="status" column="status" />
        <result property="durationMs" column="duration_ms" />
        <result property="inputJson" column="input_json" />
        <result property="outputJson" column="output_json" />
        <result property="errorStack" column="error_stack" />
        <result property="startTime" column="start_time" />
        <result property="endTime" column="end_time" />
        <result property="createdAt" column="created_at" />
        <result property="updatedAt" column="updated_at" />
    </resultMap>

    <resultMap id="FlowInstanceLogResultMap" type="com.flow.eda.web.flow.instance.FlowInstanceLogDO">
        <id property="id" column="id" />
        <result property="instanceId" column="instance_id" />
        <result property="nodeId" column="node_id" />
        <result property="level" column="level" />
        <result property="category" column="category" />
        <result property="message" column="message" />
        <result property="payloadJson" column="payload_json" />
        <result property="logTime" column="log_time" />
        <result property="createdAt" column="created_at" />
    </resultMap>

    <insert id="insertInstance">
        INSERT INTO flow_instance
        (id, flow_id, status, trigger_user, terminate_reason, retry_count, start_time, end_time, created_at, updated_at)
        VALUES
        (#{id}, #{flowId}, #{status}, #{triggerUser}, #{terminateReason}, #{retryCount}, #{startTime}, #{endTime}, #{createdAt}, #{updatedAt})
    </insert>

    <update id="updateInstance">
        UPDATE flow_instance
        <set>
            <if test="flowId != null">flow_id = #{flowId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="triggerUser != null">trigger_user = #{triggerUser},</if>
            <if test="terminateReason != null">terminate_reason = #{terminateReason},</if>
            <if test="retryCount != null">retry_count = #{retryCount},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            updated_at = #{updatedAt}
        </set>
        WHERE id = #{id}
    </update>

    <select id="selectInstanceById" resultMap="FlowInstanceResultMap">
        SELECT * FROM flow_instance WHERE id = #{instanceId}
    </select>

    <select id="selectInstancesByFlowId" resultMap="FlowInstanceResultMap">
        SELECT * FROM flow_instance WHERE flow_id = #{flowId} ORDER BY created_at DESC
    </select>

    <insert id="insertNodes">
        INSERT INTO flow_instance_node
        (instance_id, node_id, node_name, node_type, status, duration_ms, input_json, output_json, error_stack, start_time, end_time, created_at, updated_at)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.instanceId}, #{item.nodeId}, #{item.nodeName}, #{item.nodeType}, #{item.status}, #{item.durationMs},
            #{item.inputJson}, #{item.outputJson}, #{item.errorStack}, #{item.startTime}, #{item.endTime}, #{item.createdAt}, #{item.updatedAt})
        </foreach>
    </insert>

    <select id="selectNodesByInstanceId" resultMap="FlowInstanceNodeResultMap">
        SELECT * FROM flow_instance_node WHERE instance_id = #{instanceId} ORDER BY created_at ASC
    </select>

    <insert id="insertLogs">
        INSERT INTO flow_instance_log
        (instance_id, node_id, level, category, message, payload_json, log_time, created_at)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.instanceId}, #{item.nodeId}, #{item.level}, #{item.category}, #{item.message}, #{item.payloadJson},
            #{item.logTime}, #{item.createdAt})
        </foreach>
    </insert>

    <select id="selectLogsByInstanceId" resultMap="FlowInstanceLogResultMap">
        SELECT * FROM flow_instance_log WHERE instance_id = #{instanceId} ORDER BY log_time ASC, id ASC
    </select>

    <delete id="deleteInstancesByFlowId">
        DELETE FROM flow_instance WHERE flow_id = #{flowId}
    </delete>

    <delete id="deleteNodesByInstanceIds">
        DELETE FROM flow_instance_node WHERE instance_id IN
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteLogsByInstanceIds">
        DELETE FROM flow_instance_log WHERE instance_id IN
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
